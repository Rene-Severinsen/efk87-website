// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Club {
  id           String           @id
  name         String
  slug         String           @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  settings     ClubSettings?
  theme        ClubTheme?
  memberships  ClubMembership[]
  pages        Page[]
  publicPages  PublicPage[]
  featureTiles PublicHomeFeatureTile[]
  homeInfoCards PublicHomeInfoCard[]
  flightIntents ClubFlightIntent[]
  publicFooter  PublicClubFooter?
  publicSponsors PublicSponsor[]
  dailyActivity MemberDailyActivity[]
  mailingLists  ClubMailingList[]
  galleryAlbums GalleryAlbum[]
  galleryImages GalleryImage[]
  articles      Article[]
  articleTags   ArticleTag[]
  memberProfiles ClubMemberProfile[]
  memberCertificates ClubMemberCertificate[]
  calendarEntries ClubCalendarEntry[]
  forumCategories ClubForumCategory[]
  forumThreads    ClubForumThread[]
  forumReplies    ClubForumReply[]
}

model PublicClubFooter {
  id           String   @id @default(cuid())
  clubId       String   @unique
  description  String?
  addressLine1 String?
  addressLine2 String?
  email        String?
  phone        String?
  cvr          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
}

model PublicSponsor {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  href      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@index([clubId, sortOrder])
  @@index([clubId, isActive])
}

enum PublicSurfaceVisibility {
  PUBLIC
  MEMBERS_ONLY
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id             String                  @id @default(cuid())
  clubId         String
  slug           String
  title          String
  excerpt        String?
  body           String
  heroImageUrl   String?
  status         ArticleStatus
  visibility     PublicSurfaceVisibility
  isFeatured     Boolean                 @default(false)
  authorName     String?
  publishedAt    DateTime?
  legacySource   String?
  legacyId       String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  club     Club            @relation(fields: [clubId], references: [id])
  tags     ArticleTagAssignment[]

  @@unique([clubId, slug])
  @@index([clubId, status, visibility])
  @@index([clubId, isFeatured])
  @@index([clubId, publishedAt])
  @@index([clubId, legacySource, legacyId])
}

model ClubCalendarEntry {
  id                 String    @id @default(cuid())
  clubId             String
  title              String
  descriptionHtml    String?
  startsAt           DateTime
  endsAt             DateTime?
  location           String?
  isPublished        Boolean   @default(true)
  forceShowInMarquee Boolean   @default(false)
  sortOrder          Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@index([clubId, startsAt])
  @@index([clubId, isPublished])
}

model ArticleTag {
  id        String   @id @default(cuid())
  clubId    String
  slug      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club     Club                   @relation(fields: [clubId], references: [id])
  articles ArticleTagAssignment[]

  @@unique([clubId, slug])
}

model ArticleTagAssignment {
  articleId String
  tagId     String

  article Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     ArticleTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model PublicHomeInfoCard {
  id        String   @id @default(cuid())
  clubId    String
  title     String
  body      String
  badge1    String?
  badge2    String?
  badge3    String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  visibility PublicSurfaceVisibility @default(PUBLIC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@index([clubId, sortOrder])
  @@index([clubId, isActive])
  @@index([clubId, visibility, isActive])
  @@index([clubId, visibility, sortOrder])
}

model ClubFlightIntent {
  id           String                 @id @default(cuid())
  clubId       String
  userId       String
  displayName  String
  message      String?
  activityType ClubFlightIntentType
  status       ClubFlightIntentStatus @default(ACTIVE)
  source       ClubFlightIntentSource @default(MANUAL)
  visibility   ClubFlightIntentVisibility @default(PUBLIC)
  flightDate   DateTime
  plannedAt    DateTime?
  expiresAt    DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([clubId, status, createdAt])
  @@index([clubId, flightDate, status])
  @@index([clubId, flightDate, visibility])
  @@index([clubId, plannedAt])
  @@index([clubId, activityType, createdAt])
  @@index([clubId, source, createdAt])
  @@index([userId])
}

model GalleryAlbum {
  id            String             @id @default(cuid())
  clubId        String
  slug          String
  title         String
  description   String?
  coverImageUrl String?
  status        GalleryAlbumStatus
  visibility    PublicSurfaceVisibility @default(PUBLIC)
  sortOrder     Int                @default(0)
  legacySource  String?
  legacyId      String?
  publishedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  club   Club           @relation(fields: [clubId], references: [id])
  images GalleryImage[]

  @@unique([clubId, slug])
  @@index([clubId, status, visibility])
  @@index([clubId, legacySource, legacyId])
}

model GalleryImage {
  id           String             @id @default(cuid())
  clubId       String
  albumId      String
  title        String?
  caption      String?
  imageUrl     String
  thumbnailUrl String?
  sortOrder    Int                @default(0)
  status       GalleryImageStatus
  legacySource String?
  legacyId     String?
  takenAt      DateTime?
  uploadedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  club  Club         @relation(fields: [clubId], references: [id])
  album GalleryAlbum @relation(fields: [albumId], references: [id])

  @@index([clubId, albumId, status])
  @@index([clubId, legacySource, legacyId])
}

enum GalleryAlbumStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum GalleryImageStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum ClubFlightIntentType {
  FLYING
  MAINTENANCE
  WEATHER_DEPENDENT
  TRAINING
  SOCIAL
  OTHER
}

enum ClubFlightIntentStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum ClubFlightIntentSource {
  MANUAL
  ADMIN_SEED
  FUTURE_MEMBER_APP
}

enum ClubFlightIntentVisibility {
  PUBLIC
  MEMBERS_ONLY
}

model PublicHomeFeatureTile {
  id          String   @id @default(cuid())
  clubId      String
  title       String
  description String
  href        String
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  visibility  PublicSurfaceVisibility @default(PUBLIC)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@index([clubId, sortOrder])
  @@index([clubId, isActive])
  @@index([clubId, visibility, isActive])
  @@index([clubId, visibility, sortOrder])
}

model ClubTheme {
  id              String   @id @default(cuid())
  clubId          String   @unique
  backgroundColor String
  panelColor      String
  panelSoftColor  String
  lineColor       String
  textColor       String
  mutedTextColor  String
  accentColor     String
  accentColor2    String
  shadowValue     String
  radiusValue     String
  heroImageUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
}

model ClubSettings {
  id            String  @id @default(cuid())
  clubId        String  @unique
  displayName   String
  shortName     String
  primaryDomain String?
  publicEmail   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  memberships   ClubMembership[]
  accounts      Account[]
  sessions      Session[]
  flightIntents ClubFlightIntent[]
  dailyActivity MemberDailyActivity[]
  memberProfiles ClubMemberProfile[]
  memberCertificates ClubMemberCertificate[]
  forumThreads    ClubForumThread[]
  forumReplies    ClubForumReply[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ClubForumCategory {
  id          String   @id @default(cuid())
  clubId      String
  title       String
  description String?
  notificationEmail String?
  slug        String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club    Club              @relation(fields: [clubId], references: [id])
  threads ClubForumThread[]

  @@unique([clubId, slug])
  @@index([clubId, sortOrder])
}

model ClubForumThread {
  id             String   @id @default(cuid())
  clubId         String
  categoryId     String
  authorUserId   String
  title          String
  slug           String
  bodyHtml       String
  iconKey        String
  isPinned       Boolean  @default(false)
  isLocked       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActivityAt DateTime @default(now())
  replyCount     Int      @default(0)

  club     Club              @relation(fields: [clubId], references: [id])
  category ClubForumCategory @relation(fields: [categoryId], references: [id])
  author   User              @relation(fields: [authorUserId], references: [id])
  replies  ClubForumReply[]

  @@unique([clubId, categoryId, slug])
  @@index([clubId, categoryId, lastActivityAt])
  @@index([authorUserId])
}

model ClubForumReply {
  id           String   @id @default(cuid())
  clubId       String
  threadId     String
  authorUserId String
  bodyHtml     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isDeleted    Boolean  @default(false)

  club   Club            @relation(fields: [clubId], references: [id])
  thread ClubForumThread @relation(fields: [threadId], references: [id])
  author User            @relation(fields: [authorUserId], references: [id])

  @@index([clubId, threadId, createdAt])
  @@index([authorUserId])
}

model ClubMembership {
  id        String           @id @default(cuid())
  clubId    String
  userId    String
  role      ClubRole         @default(MEMBER)
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
}

model Page {
  id        String   @id @default(cuid())
  clubId    String
  slug      String
  title     String
  content   String?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@unique([clubId, slug])
  @@index([clubId])
}

model PublicPage {
  id        String           @id @default(cuid())
  clubId    String
  slug      String
  title     String
  excerpt   String?
  body      String
  status    PublicPageStatus @default(DRAFT)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@unique([clubId, slug])
  @@index([clubId])
}

enum PublicPageStatus {
  DRAFT
  PUBLISHED
}

enum ClubRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

model MemberDailyActivity {
  id           String   @id @default(cuid())
  clubId       String
  userId       String
  activityDate DateTime
  firstSeenAt  DateTime
  lastSeenAt   DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([clubId, userId, activityDate])
  @@index([clubId, activityDate])
  @@index([userId, activityDate])
}

model ClubMailingList {
  id           String                  @id @default(cuid())
  clubId       String
  key          String
  name         String
  description  String?
  emailAddress String
  purpose      ClubMailingListPurpose
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@unique([clubId, key])
  @@index([clubId, purpose])
  @@index([clubId, isActive])
}

enum ClubMailingListPurpose {
  GENERAL
  FLIGHT_INTENT
  SCHOOL
  TRIP
  OTHER
}

enum ClubMemberMembershipType {
  SENIOR
  JUNIOR
  PASSIVE
}

enum ClubMemberRoleType {
  REGULAR
  BOARD_MEMBER
  BOARD_SUPPLEANT
  TREASURER
  CHAIRMAN
  VICE_CHAIRMAN
}

enum ClubMemberSchoolStatus {
  APPROVED
  STUDENT
  NOT_APPROVED
}

enum ClubMemberStatus {
  ACTIVE
  RESIGNED
  NEW
}

enum ClubMemberCertificateType {
  A_CERTIFICATE
  A_CONTROLLER
  A_LARGE_MODEL
  A_LARGE_MODEL_CONTROLLER
  S_CERTIFICATE
  S_CONTROLLER
  S_LARGE_MODEL
  S_LARGE_MODEL_CONTROLLER
  H_CERTIFICATE
  H_CONTROLLER
  H_LARGE_MODEL
  H_LARGE_MODEL_CONTROLLER
  J_LARGE_MODEL
  J_LARGE_MODEL_CONTROLLER
}

model ClubMemberProfile {
  id              String                  @id @default(cuid())
  clubId          String
  userId          String
  firstName       String?
  lastName        String?
  addressLine     String?
  postalCode      String?
  city            String?
  mobilePhone     String?
  memberNumber    Int?
  mdkNumber       String?
  profileImageUrl String?
  membershipType  ClubMemberMembershipType @default(SENIOR)
  memberRoleType  ClubMemberRoleType       @default(REGULAR)
  schoolStatus    ClubMemberSchoolStatus   @default(NOT_APPROVED)
  memberStatus    ClubMemberStatus         @default(NEW)
  isInstructor    Boolean                  @default(false)
  birthDate       DateTime?
  joinedAt        DateTime?
  legacySource    String?
  legacyId        String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([clubId, userId])
  @@unique([clubId, memberNumber])
  @@index([clubId, memberStatus])
  @@index([clubId, membershipType])
  @@index([clubId, schoolStatus])
  @@index([clubId, memberRoleType])
  @@index([clubId, memberNumber])
  @@index([clubId, legacySource, legacyId])
}

model ClubMemberCertificate {
  id              String                    @id @default(cuid())
  clubId          String
  userId          String
  certificateType ClubMemberCertificateType
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([clubId, userId, certificateType])
  @@index([clubId, certificateType])
}