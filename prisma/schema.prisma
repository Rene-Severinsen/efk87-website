// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Club {
  id           String           @id
  name         String
  slug         String           @unique
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  settings     ClubSettings?
  theme        ClubTheme?
  memberships  ClubMembership[]
  pages        Page[]
  publicPages  PublicPage[]
  featureTiles PublicHomeFeatureTile[]
  homeInfoCards PublicHomeInfoCard[]
  flightIntents ClubFlightIntent[]
  publicFooter  PublicClubFooter?
  publicSponsors PublicSponsor[]
  dailyActivity MemberDailyActivity[]
}

model PublicClubFooter {
  id           String   @id @default(cuid())
  clubId       String   @unique
  description  String?
  addressLine1 String?
  addressLine2 String?
  email        String?
  phone        String?
  cvr          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
}

model PublicSponsor {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  href      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@index([clubId, sortOrder])
  @@index([clubId, isActive])
}

enum PublicSurfaceVisibility {
  PUBLIC
  MEMBERS_ONLY
}

model PublicHomeInfoCard {
  id        String   @id @default(cuid())
  clubId    String
  title     String
  body      String
  badge1    String?
  badge2    String?
  badge3    String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  visibility PublicSurfaceVisibility @default(PUBLIC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@index([clubId, sortOrder])
  @@index([clubId, isActive])
  @@index([clubId, visibility, isActive])
  @@index([clubId, visibility, sortOrder])
}

model ClubFlightIntent {
  id           String                 @id @default(cuid())
  clubId       String
  userId       String
  displayName  String
  message      String?
  activityType ClubFlightIntentType
  status       ClubFlightIntentStatus @default(ACTIVE)
  source       ClubFlightIntentSource @default(MANUAL)
  visibility   ClubFlightIntentVisibility @default(PUBLIC)
  flightDate   DateTime
  plannedAt    DateTime?
  expiresAt    DateTime?
  cancelledAt  DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([clubId, status, createdAt])
  @@index([clubId, flightDate, status])
  @@index([clubId, flightDate, visibility])
  @@index([clubId, plannedAt])
  @@index([clubId, activityType, createdAt])
  @@index([clubId, source, createdAt])
  @@index([userId])
}

enum ClubFlightIntentType {
  FLYING
  MAINTENANCE
  WEATHER_DEPENDENT
  TRAINING
  SOCIAL
  OTHER
}

enum ClubFlightIntentStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum ClubFlightIntentSource {
  MANUAL
  ADMIN_SEED
  FUTURE_MEMBER_APP
}

enum ClubFlightIntentVisibility {
  PUBLIC
  MEMBERS_ONLY
}

model PublicHomeFeatureTile {
  id          String   @id @default(cuid())
  clubId      String
  title       String
  description String
  href        String
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  visibility  PublicSurfaceVisibility @default(PUBLIC)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@index([clubId, sortOrder])
  @@index([clubId, isActive])
  @@index([clubId, visibility, isActive])
  @@index([clubId, visibility, sortOrder])
}

model ClubTheme {
  id              String   @id @default(cuid())
  clubId          String   @unique
  backgroundColor String
  panelColor      String
  panelSoftColor  String
  lineColor       String
  textColor       String
  mutedTextColor  String
  accentColor     String
  accentColor2    String
  shadowValue     String
  radiusValue     String
  heroImageUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
}

model ClubSettings {
  id            String  @id @default(cuid())
  clubId        String  @unique
  displayName   String
  shortName     String
  primaryDomain String?
  publicEmail   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  memberships   ClubMembership[]
  accounts      Account[]
  sessions      Session[]
  flightIntents ClubFlightIntent[]
  dailyActivity MemberDailyActivity[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ClubMembership {
  id        String           @id @default(cuid())
  clubId    String
  userId    String
  role      ClubRole         @default(MEMBER)
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
}

model Page {
  id        String   @id @default(cuid())
  clubId    String
  slug      String
  title     String
  content   String?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@unique([clubId, slug])
  @@index([clubId])
}

model PublicPage {
  id        String           @id @default(cuid())
  clubId    String
  slug      String
  title     String
  excerpt   String?
  body      String
  status    PublicPageStatus @default(DRAFT)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@unique([clubId, slug])
  @@index([clubId])
}

enum PublicPageStatus {
  DRAFT
  PUBLISHED
}

enum ClubRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

model MemberDailyActivity {
  id           String   @id @default(cuid())
  clubId       String
  userId       String
  activityDate DateTime
  firstSeenAt  DateTime
  lastSeenAt   DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([clubId, userId, activityDate])
  @@index([clubId, activityDate])
  @@index([userId, activityDate])
}